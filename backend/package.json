{
  "name": "nlf-database-api",
  "version": "1.0.0",
  "description": "RESTful API for NLF Database Management with Python FastAPI and PostgreSQL",
  "main": "app/main.py",
  "scripts": {
    "dev": ".\\venv\\Scripts\\python.exe -m uvicorn app.main:app --reload --host 0.0.0.0 --port 8000",
    "prod": ".\\venv\\Scripts\\python.exe -m uvicorn app.main:app --host 0.0.0.0 --port 8000",
    "test": ".\\venv\\Scripts\\python.exe -m pytest tests/ -v --cov=app",
    "test-watch": "pytest tests/ -v --cov=app --watch",
    "lint": "flake8 app tests",
    "format": "black app tests",
    "db-migrate": "alembic upgrade head",
    "db-makemigration": "alembic revision --autogenerate -m \"new migration\"",
    "db-downgrade": "alembic downgrade -1",
    "db-seed": "python scripts/seed_database.py"
  },
  "keywords": ["fastapi", "postgresql", "sqlalchemy", "rest-api", "python"],
  "author": "Your Company",
  "license": "AGPL-3.0-or-later"
}
