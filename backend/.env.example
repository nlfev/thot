# NLF Database Backend - Environment Variables Example
# Copy this file to .env and customize values for your environment

# ============================================================
# ENVIRONMENT
# ============================================================
ENVIRONMENT=development
# Options: development, testing, production

# ============================================================
# APPLICATION CONFIGURATION
# ============================================================
# These values are exposed via the /api/v1/config endpoint
APP_NAME=NLF Database
APP_VERSION=1.0.0
COMPANY_NAME=Your Company
LOGO_URL=/static/logo.png
COPYRIGHT_YEAR=2026

# ============================================================
# SECURITY
# ============================================================
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=dev-secret-key-change-in-production

# Access token lifetime (minutes)
# Default: 60
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Token refresh interval (minutes) - refreshes 5 min before expiry
TOKEN_REFRESH_INTERVAL_MINUTES=55

# Session timeout (minutes)
SESSION_TIMEOUT_MINUTES=60

# Login security
MAX_UNSUCCESSFUL_LOGINS=5
# Grace period starts at 3 failed logins and uses this duration (minutes)
GRACE_PERIOD_MINUTES_3_ATTEMPTS=5
# From 5 failed logins onward, this longer duration (minutes) is used
GRACE_PERIOD_MINUTES_5_ATTEMPTS=10

# ============================================================
# DATABASE
# ============================================================
DB_HOST=localhost
DB_PORT=5432
DB_USER=nlf_user
DB_PASSWORD=nlf_password
DB_NAME=nlf_db_dev
# For testing: nlf_db_test
# For production: nlf_db_prod

# ============================================================
# SMTP CONFIGURATION (Email)
# ============================================================
# Gmail: smtp.gmail.com (port 587, TLS)
# Office 365: smtp.office365.com (port 587, TLS)
# Postfix (local): localhost (port 25, no auth)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=noreply@example.com
SMTP_FROM_NAME=NLF Database

# ============================================================
# FRONTEND CONFIGURATION
# ============================================================
FRONTEND_URL=http://localhost:5173
# For production: https://yourdomain.com

# URL shown in Swagger/OpenAPI metadata as Terms of Service link
API_TERMS_OF_SERVICE_URL=http://localhost:5173/terms-of-service

# ============================================================
# CORS CONFIGURATION
# ============================================================
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ============================================================
# LANGUAGES
# ============================================================
DEFAULT_LANGUAGE=en
# Supported: en, de

# ============================================================
# UI CONFIGURATION
# ============================================================
ITEMS_PER_PAGE_DEFAULT=10

# ============================================================
# FEATURE FLAGS
# ============================================================
# Enable/disable features without code changes
FEATURE_OTP_ENABLED=true
FEATURE_EMAIL_VERIFICATION_ENABLED=true
FEATURE_CORPORATE_APPROVALS_ENABLED=true
# Disable public self-registration after first user exists.
# When enabled, only authenticated support/admin users can create new registrations.
CLOSED_REGISTRATION=false
# When enabled, parts of application are available for public use.
PUBLIC_USE=true

# ============================================================
# FILE UPLOAD CONFIGURATION
# ============================================================
# Directory for uploaded files (absolute path or relative to backend directory)
# Default: ./uploads (relative to backend folder)
# PDFs are stored below this directory in a signature-based subfolder.
UPLOAD_DIRECTORY=./uploads

# Maximum file size in bytes (50MB = 50 * 1024 * 1024)
# This value is configurable and enforced during PDF upload.
MAX_UPLOAD_SIZE=52428800

# File naming behavior
# Single-page upload: Seite_yyyyMMdd_hhmmss.pdf
# Multi-page upload: split into individual files like Seite_1.pdf, Seite_2.pdf, ...
# Storage layout:
# - Original upload path (orgin_file): {signature}/origin/{filename}.pdf
# - Searchable output path (current_file): {signature}/current/{filename}_current.pdf

# Allowed file extensions (comma-separated, with dots)
# Currently only PDF files are supported for pages
# ALLOWED_FILE_EXTENSIONS=.pdf

# Optional image/logo path for PDF watermark overlay (png/jpg/svg readable by reportlab)
# Can be absolute or relative to backend folder.
# Example: ./assets/watermark-logo.png
WATERMARK_IMAGE_PATH=logo.png
WATERMARK_COPYRIGHT=Company Name

# Optional logo embedded centred inside record QR codes (72x72 px, PNG with transparency recommended)
# Can be absolute or relative to backend folder.  Leave empty to generate QR codes without a logo.
# Example: ./assets/qr-logo.png
QR_CODE_LOGO_PATH=

# OCR pipeline configuration
# Enable/disable OCR processing after upload
OCR_PIPELINE_ENABLED=true

# If true, upload fails when OCR processing cannot be executed.
# If false, current_file falls back to a copied PDF.
OCR_PIPELINE_REQUIRED=false

# If true, OCR runs in a background worker after upload/update so the request returns quickly.
# When OCR_PIPELINE_REQUIRED=true, processing is forced inline to preserve error semantics.
OCR_PIPELINE_ASYNC=true

# Number of background OCR workers.
OCR_PIPELINE_MAX_WORKERS=1

# OCR language configuration for OCRmyPDF/Tesseract
OCR_LANGUAGES=deu+deu_latf+eng

# Render DPI used during OpenCV preprocessing
OCR_DPI=300

# OCRmyPDF --optimize level: 0=disabled (no external optimizer tools needed),
# 1=lossless, 2=lossy, 3=max. Default is 0 to avoid [WinError 2] from missing
# optional tools like jbig2enc, pngquant, optipng.
OCR_OPTIMIZE=0

# OCR executables (from PATH or absolute file path)
# Example for this project layout on Windows when using the local venv:
# OCRMY_PDF_BIN=./venv/Scripts/ocrmypdf.exe
# Tesseract and unpaper are external tools and usually need a system installation.
# Example absolute path after local installation:
# TESSERACT_BIN=C:/Program Files/Tesseract-OCR/tesseract.exe
# GS_BIN=C:/Program Files/gs/gs10.03.1/bin/gswin64c.exe
# UNPAPER_BIN=C:/ProgramData/chocolatey/bin/unpaper.exe
GS_BIN=gswin64c
TESSERACT_BIN=tesseract
OCRMY_PDF_BIN=ocrmypdf
UNPAPER_BIN=unpaper
KRAKEN_BIN=kraken

# Page number detection priority after OCR.
# Allowed values: book,stamp or stamp,book
OCR_PAGE_NUMBER_PRIORITY=book,stamp

# Kraken activation controls (handwriting-focused pages)
# Kraken is optional and not installed by default in requirements.txt
KRAKEN_ENABLED=false
KRAKEN_MIN_HANDWRITING_PAGES=1
KRAKEN_MIN_HANDWRITING_RATIO=0.5

# ============================================================
# LEGAL HTML CONTENT (not versioned in git)
# ============================================================
# Directory containing language-specific legal HTML files.
# Files are loaded by backend endpoint: /api/v1/config/legal/{document}?lang={en|de}
LEGAL_CONTENT_DIRECTORY=./legal_content

# Expected file name templates in LEGAL_CONTENT_DIRECTORY
LEGAL_IMPRINT_FILENAME_TEMPLATE=imprint.{lang}.html
LEGAL_DATA_PROTECTION_FILENAME_TEMPLATE=data-protection.{lang}.html
LEGAL_TERMS_OF_SERVICE_FILENAME_TEMPLATE=terms-of-service.{lang}.html

# ============================================================
# LOGGING
# ============================================================
LOG_LEVEL=INFO
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL

# Email change token expiry for user-initiated process (in hours)
EMAIL_CHANGE_TOKEN_EXPIRE_HOURS=1
# Email change token expiry for support/admin-initiated process (in hours)
SUPPORT_EMAIL_CHANGE_TOKEN_EXPIRE_HOURS=24

# ============================================================
# PAGES API CONFIGURATION
# ============================================================
# Default limit for /pages endpoint (list_pages)
# Controls how many pages are returned by default in the gallery and API.
# Can be overridden per request with the 'limit' query parameter.
PAGES_LIST_DEFAULT_LIMIT=100

# PDF watermark alpha (opacity) for overlay images (0.0 = transparent, 1.0 = opaque)
PDF_WATERMARK_IMAGE_ALPHA=0.15

# Show citation link in PDF watermark (true/false)
PDF_WATERMARK_SHOW_CITATION_LINK=true

# Link for pers_count column in records table
RECORDS_PERS_COUNT_LINK=https://example.com/
