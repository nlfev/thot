# Frontend Environment Variables - Production
# Copy this file to .env.production and customize for your production environment

# Backend API Base URL (without /api/v1 suffix)
# Replace with your production domain
VITE_BACKEND_URL=https://api.yourdomain.com

# API URL (full path to API endpoints)
VITE_API_URL=https://api.yourdomain.com/api/v1

# public URL to the source code repository (shown on About page)
VITE_SOURCE_REPO_URL=https://github.com/nlfev/thot
